<nav id="sticky-nav" class="sticky-nav" aria-label="Section navigation">
  <a href="#hero" class="sticky-nav-name">juliana meyer</a>
  <ul class="sticky-nav-links">
    <li><a href="#tech-writing">How does this work?</a></li>
    <li><a href="#community">Where is everyone?</a></li>
    <li><a href="#podcast">How do others do this?</a></li>
