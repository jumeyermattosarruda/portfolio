---
const base = import.meta.env.BASE_URL;
---
<section id="hero" class="hero">

  <!-- ─── Left column ──────────────────────────────────────────────── -->
  <div class="hero-left">

    <!-- Name + arch photo -->
    <div class="name-photo-unit">
      <div class="name-block">
        <span class="hl-first">Juliana</span>
        <span class="hl-last">Meyer</span>
        <span class="hl-role">Senior Product Marketing Manager</span>
      </div>
      <div class="arch-photo">
        <div class="arch-frame">
          <img src={`${base}images/cases/profile.jpg`} alt="Juliana Meyer" />
        </div>
      </div>
    </div>

    <!-- Tagline + creds -->
    <div class="hl-bottom">
      <div class="hl-tagline">I help products find their people, and their people understand the product.</div>
      <div class="hl-creds">DevPortal Award 2023 · 35K+ developers · 5M+ reach</div>
    </div>

    <!-- Easter egg — Side Quests -->
    <a class="easter-egg" href="#building-now">
      <div class="ee-icon">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M6 1 L7 4.5 L10.5 6 L7 7.5 L6 11 L5 7.5 L1.5 6 L5 4.5 Z" stroke="#f48eb8" stroke-width="0.8" fill="none"/>
        </svg>
      </div>
      <div>
        <div class="ee-q">"What am I building?"</div>
        <div class="ee-label">Side Quests ↗</div>
      </div>
    </a>

  </div>

  <!-- ─── Right column ─────────────────────────────────────────────── -->
  <div class="hero-right">

    <div class="hr-intro">
      <div class="hr-label">Curiosity as a career strategy</div>
      <div class="hr-invite">Explore the questions that guided my path ↓</div>
    </div>

    <!-- 6-cell cluster grid -->
    <div class="cluster-grid">

      <!-- 1 — Product Marketing -->
      <a href="#case-studies" class="cc">
        <div class="cc-icon">
          <svg width="24" height="24" viewBox="0 0 36 36" fill="none">
            <path d="M18 4 L20 15 L30 18 L20 21 L18 32 L16 21 L6 18 L16 15 Z" stroke="#8a5a44" stroke-width="1.2" fill="none"/>
            <circle cx="18" cy="18" r="2" fill="#f48eb8"/>
          </svg>
        </div>
        <div class="cc-q">"Why should people use this?"</div>
        <div class="cc-role">Product Marketing</div>
        <div class="cc-cred">VTEX · iConnections · 5M+ reach</div>
      </a>

      <!-- 2 — The Pivot -->
      <a href="#why-pmm" class="cc">
        <div class="cc-icon">
          <svg width="24" height="24" viewBox="0 0 32 32" fill="none">
            <rect x="4" y="10" width="10" height="18" rx="2" stroke="#8a5a44" stroke-width="1.2"/>
            <rect x="18" y="4" width="10" height="24" rx="2" stroke="#f48eb8" stroke-width="1.2"/>
          </svg>
        </div>
        <div class="cc-q">"Why Product Marketing?"</div>
        <div class="cc-role">The Pivot</div>
        <div class="cc-cred">Tech → GTM · Venn diagram career</div>
      </a>

      <!-- 3 — TW Community -->
      <a href="#community" class="cc">
        <div class="cc-icon">
          <svg width="24" height="24" viewBox="0 0 36 36" fill="none">
            <path d="M18 4 L18 32 M4 18 L32 18 M7 7 L29 29 M29 7 L7 29" stroke="#8a5a44" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="cc-q">"Where is everyone?"</div>
        <div class="cc-role">TW Community</div>
        <div class="cc-cred">Tech Writing BR · Co-founder · 300+</div>
      </a>

      <!-- 4 — Podcasting -->
      <a href="#podcast" class="cc">
        <div class="cc-icon">
          <svg width="24" height="20" viewBox="0 0 36 28" fill="none">
            <path d="M2 14 Q8 4 14 14 Q20 24 26 14 Q32 4 34 14" stroke="#8a5a44" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="cc-q">"How do others do this?"</div>
        <div class="cc-role">Podcasting</div>
        <div class="cc-cred">30+ episodes · The Manuscript · Daily PMM</div>
      </a>

      <!-- 5 — Tech Writing -->
      <a href="#tech-writing" class="cc">
        <div class="cc-icon">
          <svg width="24" height="24" viewBox="0 0 36 36" fill="none">
            <path d="M18 4 L20 15 L30 18 L20 21 L18 32 L16 21 L6 18 L16 15 Z" fill="#f48eb8" opacity="0.9"/>
          </svg>
        </div>
        <div class="cc-q">"How does tech work?"</div>
        <div class="cc-role">Tech Writing</div>
        <div class="cc-cred">DevPortal Award · 35K+ devs</div>
      </a>

      <!-- 6 — International Experiences -->
      <a href="#abroad" class="cc cc--muted">
        <div class="cc-icon">
          <svg width="24" height="24" viewBox="0 0 36 36" fill="none">
            <circle cx="18" cy="18" r="13" stroke="#8a5a44" stroke-width="1.2"/>
            <path d="M5 18 Q11 11 18 18 Q25 25 31 18" stroke="#8a5a44" stroke-width="1" fill="none"/>
            <path d="M10 10 Q14 6 18 10" stroke="#f48eb8" stroke-width="1" fill="none" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="cc-q">"What is out there?"</div>
        <div class="cc-role">International Experiences</div>
        <div class="cc-cred">Mexico · Spain · Panama · UK</div>
      </a>

    </div><!-- /cluster-grid -->
  </div><!-- /hero-right -->
</section>
