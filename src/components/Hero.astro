---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<section id="hero" class="hero">

  <!-- ─── Left column ──────────────────────────────────────────────── -->
  <div class="hero-left">

    <!-- Name + arch photo -->
    <div class="name-photo-unit">
      <h1 class="name-block">
        <span class="hl-first">Juliana</span>
        <span class="hl-last">Meyer</span>
        <span class="hl-role">Senior Product Marketing Manager</span>
      </h1>
      <div class="arch-photo">
        <div class="arch-frame">
          <img src={`${base}images/profile/profile-1.jpg`} alt="Juliana Meyer" />
          <img src={`${base}images/profile/profile-2.jpg`} alt="Juliana Meyer" />
          <img src={`${base}images/profile/profile-3.jpg`} alt="Juliana Meyer" />
          <img src={`${base}images/profile/profile-4.jpg`} alt="Juliana Meyer" />
          <img src={`${base}images/profile/profile-5.jpg`} alt="Juliana Meyer" />
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="hero-cta">
      <a href="https://www.linkedin.com/in/oijulianameyer/" target="_blank" rel="noopener noreferrer" class="cta-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        Connect on LinkedIn
      </a>
      <a href="mailto:jumeyermattosarruda@gmail.com" class="cta-secondary">
        Get in touch ↗
      </a>
    </div>

    <!-- Tagline + creds -->
    <div class="hl-bottom">
      <p class="hl-tagline">GTM strategy for 40+ products. DevPortal Award. Tech PMM, fluent in GitHub and positioning.</p>
      <p class="hl-creds">iConnections · VTEX · DevPortal Award 2023 · 5M+ reach</p>
    </div>

    <!-- Easter egg — Side Quests -->
    <a class="easter-egg" href="#building-now">
      <div class="ee-icon">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M6 1 L7 4.5 L10.5 6 L7 7.5 L6 11 L5 7.5 L1.5 6 L5 4.5 Z" stroke="#f48eb8" stroke-width="0.8" fill="none"/>
        </svg>
      </div>
      <div>
        <div class="ee-q">"What am I building?"</div>
        <div class="ee-label">Side Quests ↗</div>
      </div>
    </a>

  </div>

  <!-- ─── Right column ─────────────────────────────────────────────── -->
  <div class="hero-right">

    <div class="hr-intro">
      <div class="hr-label">Curiosity as a career strategy</div>
      <div class="hr-invite">Explore the questions that guided my path ↓</div>
    </div>

    <!-- 6-cell cluster grid -->
    <nav aria-label="Career chapters">
    <div class="cluster-grid">

      <!-- 1 — Product Marketing -->
      <a href="#case-studies" class="cc cc-primary">
        <div class="cc-icon">
          <svg width="24" height="24" viewBox="0 0 36 36" fill="none">
            <path d="M18 4 L20 15 L30 18 L20 21 L18 32 L16 21 L6 18 L16 15 Z" stroke="#8a5a44" stroke-width="1.2" fill="none"/>
            <circle cx="18" cy="18" r="2" fill="#f48eb8"/>
          </svg>
        </div>
        <div class="cc-q">"Why should people use this?"</div>
        <h3 class="cc-role">Product Marketing</h3>
        <div class="cc-cred">VTEX · iConnections · 5M+ reach</div>
        <div class="cc-tags">
          <span class="cc-tag">GTM Strategy</span>
          <span class="cc-tag">Product Launches</span>
          <span class="cc-tag">5M+ reach</span>
          <span class="cc-tag">Lifecycle Marketing</span>
        </div>
      </a>

      <!-- 2 — The Pivot -->
      <a href="#why-pmm" class="cc">
        <div class="cc-icon">
          <svg width="24" height="24" viewBox="0 0 32 32" fill="none">
            <rect x="4" y="10" width="10" height="18" rx="2" stroke="#8a5a44" stroke-width="1.2"/>
            <rect x="18" y="4" width="10" height="24" rx="2" stroke="#f48eb8" stroke-width="1.2"/>
          </svg>
        </div>
        <div class="cc-q">"Why Product Marketing?"</div>
        <h3 class="cc-role">The Pivot</h3>
        <div class="cc-cred">Tech → GTM · Venn diagram career</div>
      </a>

      <!-- 3 — TW Community -->
      <a href="#community" class="cc">
        <div class="cc-icon">
          <svg width="24" height="24" viewBox="0 0 36 36" fill="none">
            <path d="M18 4 L18 32 M4 18 L32 18 M7 7 L29 29 M29 7 L7 29" stroke="#8a5a44" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="cc-q">"Where is everyone?"</div>
        <h3 class="cc-role">TW Community</h3>
        <div class="cc-cred">Tech Writing BR · Co-founder · 300+</div>
      </a>

      <!-- 4 — Podcasting -->
      <a href="#podcast" class="cc">
        <div class="cc-icon">
          <svg width="24" height="20" viewBox="0 0 36 28" fill="none">
            <path d="M2 14 Q8 4 14 14 Q20 24 26 14 Q32 4 34 14" stroke="#8a5a44" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="cc-q">"How do others do this?"</div>
        <h3 class="cc-role">Podcasting</h3>
        <div class="cc-cred">30+ episodes · The Manuscript · Daily PMM</div>
      </a>

      <!-- 5 — Tech Writing -->
      <a href="#tech-writing" class="cc cc-primary">
        <div class="cc-icon">
          <svg width="24" height="24" viewBox="0 0 36 36" fill="none">
            <path d="M18 4 L20 15 L30 18 L20 21 L18 32 L16 21 L6 18 L16 15 Z" fill="#f48eb8" opacity="0.9"/>
          </svg>
        </div>
        <div class="cc-q">"How does tech work?"</div>
        <h3 class="cc-role">Tech Writing</h3>
        <div class="cc-cred">DevPortal Award · 35K+ devs</div>
        <div class="cc-tags">
          <span class="cc-tag">DevPortal Award</span>
          <span class="cc-tag">API Docs</span>
          <span class="cc-tag">35K+ devs</span>
          <span class="cc-tag">Team Lead</span>
        </div>
      </a>

      <!-- 6 — International Experiences -->
      <a href="#abroad" class="cc cc-minor">
        <div class="cc-icon">
          <svg width="24" height="24" viewBox="0 0 36 36" fill="none">
            <circle cx="18" cy="18" r="13" stroke="#8a5a44" stroke-width="1.2"/>
            <path d="M5 18 Q11 11 18 18 Q25 25 31 18" stroke="#8a5a44" stroke-width="1" fill="none"/>
            <path d="M10 10 Q14 6 18 10" stroke="#f48eb8" stroke-width="1" fill="none" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="cc-q">"What is out there?"</div>
        <h3 class="cc-role">International Experiences</h3>
        <div class="cc-cred">Mexico · Spain · Panama · UK</div>
      </a>

    </div><!-- /cluster-grid -->
    </nav><!-- /career chapters nav -->
  </div><!-- /hero-right -->
</section>
