---
import { getCollection } from 'astro:content';
import '../styles/global.css';
import Topbar from '../components/Topbar.astro';
import Hero from '../components/Hero.astro';
import StickyNav from '../components/StickyNav.astro';
import Section from '../components/Section.astro';
import CountryTabs from '../components/CountryTabs.astro';
import Footer from '../components/Footer.astro';

const allSections = await getCollection('sections');
const sections = allSections.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  sections.map(async (entry) => {
    const { Content } = await entry.render();
    return { entry, Content };
  })
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Juliana Meyer — Senior Product Marketing Manager. Tech writing, community building, and product marketing."
    />
    <title>Juliana Meyer — Senior PMM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:ital,wght@0,300;0,400;1,300&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Topbar />
    <Hero />
    <StickyNav />
    <main>
      {
        rendered.map(({ entry, Content }) => (
          <Section {...entry.data}>
            <Content />
            {entry.data.id === 'case-studies' && (
              <div slot="extra" class="case-cards">
                {entry.data.caseStudies?.map((card) => (
                  <div class="case-card">
                    <h3 class="case-card-title">{card.title}</h3>
                    <p class="case-card-desc">{card.description}</p>
                    {card.url && card.linkLabel && (
                      <a
                        href={card.url}
                        class="case-card-link"
                        target={card.url !== '#' ? '_blank' : undefined}
                        rel={card.url !== '#' ? 'noopener noreferrer' : undefined}
                      >
                        {card.linkLabel}
                      </a>
                    )}
                  </div>
                ))}
              </div>
            )}
            {entry.data.id === 'abroad' && (
              <CountryTabs slot="extra" countries={entry.data.countries ?? []} />
            )}
          </Section>
        ))
      }
    </main>
    <Footer />
  </body>
</html>
