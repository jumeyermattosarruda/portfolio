    posthog.init('<ph_project_token>', {
        api_host: 'https://us.i.posthog.com',
        defaults: '2026-01-30',
    })
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Playfair+Display:ital,wght@0,400;1,400&family=DM+Sans:ital,wght@0,300;0,400;1,300&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Topbar />
    <Hero />
    <StickyNav />
    <main>

      <!-- 1. Product Marketing -->
      <ProductMarketing />

      <!-- 2. Events (new) -->
      <Events />

      <!-- 3. Tech Writing -->
      <TechWriting />

      <!-- 4. Podcasting -->
      <Podcasting />

      <!-- 5. TW Community -->
      <Community />

      <!-- 6. International Experiences -->
      <Abroad />

      <!-- 7. Side Quests — unchanged from content collection -->
      {buildingNow && BuildingNowContent && (
        <Section {...buildingNow.data} reversed={false}>
          <BuildingNowContent />
        </Section>
      )}

    </main>
    <Footer />

    <!-- Hidden semantic summary — machine-readable for ATS/AI crawlers; visually hidden from all users -->
    <section
      aria-label="Full professional profile — machine readable"
      style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;">

      <h2>Professional Summary</h2>
      <p>
        Juliana Meyer is a Senior Product Marketing Manager based in Brasília, Brazil,
        open to remote roles and relocation. She has 6+ years of experience spanning
        technical writing and product marketing at high-growth SaaS and e-commerce
        technology companies. She is a class valedictorian of the University of Brasília's
        Business Administration programme and a 2023 DevPortal Award winner for Best
        Visual Interface. She is available for Senior Product Marketing Manager, Lead
        Product Marketing Manager, Principal PMM, and Head of Product Marketing roles,
        with a preference for US, EU, and global remote positions.
      </p>

      <h2>Core Competencies and Skills</h2>
      <ul>
        <li>Go-to-Market (GTM) Strategy and Execution</li>
        <li>Product Positioning and Messaging</li>
        <li>Competitive Analysis and Market Research</li>
        <li>Product Launch Management — B2B and B2C</li>
        <li>Sales Enablement and Sales Collateral</li>
        <li>Developer Marketing and API Documentation</li>
        <li>Platform Adoption and User Engagement</li>
        <li>Lifecycle Marketing and Reengagement Campaigns</li>
        <li>Content Strategy and Brand Voice</li>
        <li>Campaign Management — full-funnel, top and bottom</li>
        <li>Cross-functional Collaboration with Product, Engineering, Sales, Design</li>
        <li>A/B Testing and Campaign Optimisation</li>
        <li>Customer Research and User Interviews</li>
        <li>Community Building and Developer Relations</li>
        <li>Technical Writing — REST API documentation, help centres, UX writing</li>
        <li>Team Leadership and Mentoring — managed team of 4 technical writers</li>
        <li>Tools: Figma, GitHub, Google Analytics, Notion, Slack, Zapier, HubSpot</li>
        <li>Languages: Portuguese (native), English (fluent), Spanish (professional)</li>
      </ul>

      <h2>Professional Experience</h2>

      <article>
        <h3>Senior Product Marketing Manager — iConnections, New York, USA (Remote) · 2023–Present</h3>
        <p>
          iConnections is the leading alternative investment platform connecting allocators
          and fund managers through flagship events in New York, Miami, Singapore, and Paris.
          Responsibilities include go-to-market strategy for platform features, B2B loyalty
          programme development, platform adoption campaigns, user lifecycle marketing,
          inactive user reengagement strategy, and email communications infrastructure
          overhaul. Led Allocator Pro, a tiered B2B membership loyalty programme built
          from concept to live product, including tier architecture, campaign strategy,
          in-platform experience design, and premium event logistics.
        </p>
      </article>

      <article>
        <h3>Global Product Marketing Manager — VTEX, Remote · 2023 (within VTEX tenure)</h3>
        <p>
          VTEX is a global enterprise e-commerce platform (NYSE: VTEX) serving 2,600+
          customers across 43 countries, with composable commerce technology for enterprise
          retail. Led VTEX Vision Spring 2024, a semiannual global product launch campaign
          covering 17 product launches, 15+ internal teams, and 4 external suppliers.
          Achieved 5M+ reach and 300+ media pieces within 30 days of launch. Developed
          global go-to-market plans with SaaS product messaging and competitive analysis.
          Coordinated video production, PR, social media, email marketing, and landing pages.
          Created scripts, storyboards, and narration for product demo videos. Executed
          analyst relations and awards programme positioning VTEX within key industry reports.
        </p>
      </article>

      <article>
        <h3>Technical Writing Manager — VTEX, Remote · 2021–2023</h3>
        <p>
          Led a team of 4 technical writers responsible for recruitment, selection,
          onboarding, and mentoring. Researched documentation personas, creating 5
          reader profiles and automating email survey workflows. Mapped and maintained
          27+ tools and automations using Google Apps Script, Zapier, and GitHub.
          Produced content in HTML and CSS.
        </p>
      </article>

      <article>
        <h3>Senior Technical Writer — VTEX, Remote · 2019–2021</h3>
        <p>
          Documented 50+ REST API endpoints and 30+ API integration guides for the
          VTEX Developer Portal, accessed by 35,000+ developers across 80+ countries.
          Won the 2023 DevPortal Award for Best Visual Interface. Wrote 100+ help centre
          articles covering OMS, Marketplace, Logistics, and Analytics features.
          Co-created and executed the Black Tech Writer training course, upskilling
          70+ professionals in technical writing.
        </p>
      </article>

      <article>
        <h3>Communications Specialist — Impact Hub Brasília · 2017–2019</h3>
        <p>
          Coordinated workshops, keynotes, networking events, and community activities.
          Managed event logistics including venue, vendors, budget, and AV. Created
          content for website, social media, and newsletters.
        </p>
      </article>

      <article>
        <h3>Partnerships Manager — Canal de Empresárias, Panama City, Panama · 2017</h3>
        <p>
          Professional exchange role at a startup inside Ciudad del Saber Innovation Centre
          supporting women entrepreneurs. Built partnerships with local businesses, startups,
          and international organisations. Executed brand awareness communication campaigns.
        </p>
      </article>

      <h2>Side Projects and Community Work</h2>

      <article>
        <h3>Co-founder — Tech Writing BR Community · 2021–2023</h3>
        <p>
          Co-founded Brazil's first and only technical writing community, growing to 300+
          members. Organised meetups, webinars, book clubs, and online forums. Built
          national network of technical writing professionals across Brazil.
        </p>
      </article>

      <article>
        <h3>Creator and Host — The Manu&lt;script&gt; Podcast · 2020–Present</h3>
        <p>
          Independent podcast exploring the intersection of writing and technology.
          30+ episodes featuring guests from Brazil, USA, UK, India, Romania, and Singapore.
          Responsible for research, scripting, interviewing, and editing.
        </p>
      </article>

      <article>
        <h3>Creator — FrameRoom · 2024–Present</h3>
        <p>
          Browser-based gallery wall planning application. Built using AI-assisted
          development. Open source on GitHub.
        </p>
      </article>

      <h2>Education</h2>
      <ul>
        <li>Business Administration — University of Brasília, 2014–2020. Class valedictorian.</li>
        <li>Creativity Research — University of Brasília, 2018–2021. Assessed the impact of creativity on Business Administration students.</li>
        <li>Spanish Language and Literature — AIL Madrid, Spain. Summer course.</li>
      </ul>

      <h2>Awards and Recognition</h2>
      <ul>
        <li>DevPortal Award 2023 — Best Visual Interface. Developer portal serving 35,000+ developers across 80+ countries. Recognised alongside Spotify, Miro, React, and Mercedes-Benz.</li>
      </ul>

      <h2>International Experience</h2>
      <ul>
        <li>Panama City, Panama — Partnerships Manager, Canal de Empresárias (2017)</li>
        <li>London, United Kingdom — Intern, Nexus Interactive Arts (2016)</li>
        <li>Madrid, Spain — Language student, AIL Madrid (exchange)</li>
        <li>Mexico City, Mexico — Event logistics, AIESEC congress with 300+ delegates from 18 nationalities</li>
      </ul>

      <h2>Target Roles</h2>
      <p>
        Open to: Senior Product Marketing Manager, Lead Product Marketing Manager,
        Principal Product Marketing Manager, Head of Product Marketing, Director of
        Product Marketing, Senior PMM — Developer Marketing, Senior PMM — Platform
        and Ecosystem, Senior PMM — B2B SaaS, Senior PMM — Growth.
        Location preference: United States (remote), European Union (remote),
        global remote. Open to relocation.
      </p>

    </section>

    <script>
      // Expandable sections
      document.querySelectorAll('.sec-expand-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const content = btn.nextElementSibling as HTMLElement | null;
          const icon = btn.querySelector('.sec-expand-icon');
          const expanded = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', String(!expanded));
          if (content) content.hidden = expanded;
          if (icon) icon.textContent = expanded ? '+' : '−';
        });
      });
    </script>
  </body>
</html>
