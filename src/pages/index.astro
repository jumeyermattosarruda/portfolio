---
import { getCollection } from 'astro:content';
import '../styles/global.css';
import Topbar from '../components/Topbar.astro';
import Hero from '../components/Hero.astro';
import StickyNav from '../components/StickyNav.astro';
import Section from '../components/Section.astro';
import Footer from '../components/Footer.astro';

import ProductMarketing from '../components/sections/ProductMarketing.astro';
import Events from '../components/sections/Events.astro';
import TechWriting from '../components/sections/TechWriting.astro';
import Podcasting from '../components/sections/Podcasting.astro';
import Community from '../components/sections/Community.astro';
import Abroad from '../components/sections/Abroad.astro';

const allSections = await getCollection('sections');
const buildingNow = allSections.find((s) => s.data.id === 'building-now');
const { Content: BuildingNowContent } = buildingNow ? await buildingNow.render() : { Content: null };

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Juliana Meyer — Senior Product Marketing Manager | GTM Strategy, Developer Marketing, SaaS</title>
    <meta name="description" content="Juliana Meyer is a Senior Product Marketing Manager with 6+ years across technical writing and PMM. DevPortal Award 2023 Best Interface. Led 17-product global launch with 5M+ reach at VTEX. Built B2B loyalty program at iConnections. Co-founder of Tech Writing BR. Open to Senior and Lead PMM roles in US, EU, and global remote tech." />
    <meta name="keywords" content="Product Marketing Manager, Senior PMM, Go-to-Market Strategy, GTM, Product Launch, Positioning, Messaging, Competitive Analysis, Developer Marketing, API Documentation, Technical Writing, SaaS Marketing, B2B Marketing, Campaign Management, Platform Adoption, User Engagement, Sales Enablement, Content Strategy, Community Building, Lifecycle Marketing" />
    <meta name="author" content="Juliana Meyer" />
    <meta name="robots" content="index, follow" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Juliana Meyer — Senior Product Marketing Manager" />
    <meta property="og:description" content="PMM with a technical writing foundation. DevPortal Award 2023. 5M+ campaign reach. GTM strategy, product launches, developer marketing, and platform adoption across VTEX and iConnections." />
    <meta property="og:url" content="https://jumeyermattosarruda.github.io" />
    <!-- Twitter/X card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Juliana Meyer — Senior PMM" />
    <meta name="twitter:description" content="PMM who earns engineer trust. DevPortal Award 2023. 5M+ reach. Open to senior roles globally." />
    <!-- JSON-LD structured data -->
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Juliana Meyer",
      "jobTitle": "Senior Product Marketing Manager",
      "url": "https://jumeyermattosarruda.github.io",
      "email": "jumeyermattosarruda@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Brasília",
        "addressCountry": "Brazil"
      },
      "sameAs": [
        "https://www.linkedin.com/in/oijulianameyer/",
        "https://github.com/jumeyermattosarruda"
      ],
      "alumniOf": {
        "@type": "CollegeOrUniversity",
        "name": "University of Brasília",
        "department": "Business Administration"
      },
      "award": "DevPortal Award 2023 — Best Visual Interface",
      "knowsAbout": [
        "Product Marketing","Go-to-Market Strategy","Product Positioning and Messaging",
        "Competitive Analysis","Developer Marketing","API Documentation","Technical Writing",
        "SaaS Marketing","B2B Marketing","Campaign Management","Platform Adoption",
        "User Lifecycle Marketing","Sales Enablement","Content Strategy","Community Building",
        "Cross-functional Collaboration","A/B Testing","Customer Research","Brand Awareness","Lead Generation"
      ],
      "hasOccupation": [{
        "@type": "Occupation",
        "name": "Senior Product Marketing Manager",
        "occupationLocation": { "@type": "Country", "name": "United States" }
      }]
    })}</script>
    <!-- Posthog -->
    <script>
    !function(t,e){var o,n,p,r;e.__SV||(window.posthog && window.posthog.__loaded)||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init os ds Ie us vs ss ls capture calculateEventProperties register register_once register_for_session unregister unregister_for_session ws getFeatureFlag getFeatureFlagPayload getFeatureFlagResult isFeatureEnabled reloadFeatureFlags updateFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSurveysLoaded onSessionId getSurveys getActiveMatchingSurveys renderSurvey displaySurvey cancelPendingSurvey canRenderSurvey canRenderSurveyAsync identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException startExceptionAutocapture stopExceptionAutocapture loadToolbar get_property getSessionProperty bs ps createPersonProfile setInternalOrTestUser ys es $s opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing get_explicit_consent_status is_capturing clear_opt_in_out_capturing cs debug M gs getPageViewId captureTraceFeedback captureTraceMetric Qr".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(d